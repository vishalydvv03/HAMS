{
  "openapi": "3.0.1",
  "info": {
    "title": "HAMS.API",
    "version": "1.0"
  },
  "paths": {
    "/api/auth/register/patient": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterPatientModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterPatientModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterPatientModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/register/doctor": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDoctorModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDoctorModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDoctorModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/departments": {
      "get": {
        "tags": [
          "Departments"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReadDepartment"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReadDepartment"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReadDepartment"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Departments"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/departments/{id}": {
      "get": {
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ReadDepartment"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadDepartment"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadDepartment"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddDepartment"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Departments"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/doctor/schedule/{doctorId}": {
      "get": {
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "doctorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "doctorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "day",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/WeekDay"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDoctorScheduleModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDoctorScheduleModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateDoctorScheduleModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "Schedules"
        ],
        "parameters": [
          {
            "name": "doctorId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "day",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/WeekDay"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/doctor/schedule": {
      "post": {
        "tags": [
          "Schedules"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDoctorScheduleModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AddDoctorScheduleModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AddDoctorScheduleModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddDepartment": {
        "type": "object",
        "properties": {
          "deptName": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AddDoctorScheduleModel": {
        "type": "object",
        "properties": {
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "day": {
            "$ref": "#/components/schemas/WeekDay"
          },
          "startTime": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "endTime": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "isOnLeave": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ReadDepartment": {
        "type": "object",
        "properties": {
          "departmentId": {
            "type": "integer",
            "format": "int32"
          },
          "deptName": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "doctors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ReadDoctor"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ReadDoctor": {
        "type": "object",
        "properties": {
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "doctorName": {
            "type": "string",
            "nullable": true
          },
          "specialization": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDoctorModel": {
        "required": [
          "contactNo",
          "departmentId",
          "doctorName",
          "email",
          "password",
          "specialization"
        ],
        "type": "object",
        "properties": {
          "doctorName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "contactNo": {
            "maxLength": 10,
            "minLength": 10,
            "type": "string"
          },
          "specialization": {
            "minLength": 1,
            "type": "string"
          },
          "departmentId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "RegisterPatientModel": {
        "required": [
          "address",
          "bloodGroup",
          "contactNo",
          "gender",
          "patientName"
        ],
        "type": "object",
        "properties": {
          "patientName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "contactNo": {
            "maxLength": 10,
            "minLength": 10,
            "type": "string"
          },
          "gender": {
            "maxLength": 20,
            "minLength": 1,
            "type": "string"
          },
          "bloodGroup": {
            "maxLength": 5,
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "dob": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      },
      "UpdateDoctorScheduleModel": {
        "type": "object",
        "properties": {
          "startTime": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "endTime": {
            "type": "string",
            "format": "time",
            "nullable": true
          },
          "isOnLeave": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "UserLoginModel": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "WeekDay": {
        "enum": [
          "Sunday",
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ],
        "type": "string"
      }
    }
  }
}